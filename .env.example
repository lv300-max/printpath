# PrintPath — Environment Variables
# Copy this file to .env and fill in your real values
# Run: cp .env.example .env

# ── Stripe ─────────────────────────────────────────────────────
# Get your secret key from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# ── Server ─────────────────────────────────────────────────────
# The public URL of your server (used for Stripe success/cancel redirects)
# Local dev:   http://localhost:3000
# Production:  https://yourdomain.com
BASE_URL=http://localhost:3000

# Port to run the server on (default: 3000)
PORT=3000

# ── Shop Notification ──────────────────────────────────────────
# After a paid order is created, the server POSTs order details here.
# Set to your shop's webhook URL. Leave blank to disable.
# Example: https://blendedprints.com/order
SHOP_WEBHOOK_URL=http://YOUR_SHOP_ENDPOINT/order
