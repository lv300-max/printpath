# PrintPath — Environment Variables
# Copy this file to .env and fill in your real values
# Run: cp .env.example .env

# ── Stripe ───────────────────────────────────────────────
# Publishable key — safe to expose in frontend JS
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_51T2RsdCgrKKXkcmpTeCPhct3Wu7TL6g2YWCMozluIFt9DiBkAqB4nBbvhE5glf91ksqMGmtsseiWDdxAyaX7LEaQ00skMUw6pj
# Secret key — server-side ONLY, never expose in frontend
# Set this in Netlify: Site Settings → Environment Variables
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# ── Server ─────────────────────────────────────────────────────
# The public URL of your server (used for Stripe success/cancel redirects)
# Local dev:   http://localhost:3000
# Production:  https://yourdomain.com
BASE_URL=http://localhost:3000

# Port to run the server on (default: 3000)
PORT=3000

# ── Shop Notification ──────────────────────────────────────────
# After a paid order is created, the server POSTs order details here.
# Set to your shop's webhook URL. Leave blank to disable.
# Example: https://blendedprints.com/order
SHOP_WEBHOOK_URL=http://YOUR_SHOP_ENDPOINT/order
